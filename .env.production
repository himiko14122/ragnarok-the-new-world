# ===== 生产环境变量 =====
# 注意：NEXT_PUBLIC_* 变量在构建时被内联到客户端 JS 中
# 务必在部署平台（Vercel / Cloudflare Pages 等）的环境变量面板中设置这些值

# 站点 URL
NEXT_PUBLIC_SITE_URL=https://www.ragnarok-the-new-world.wiki

# 全站广告开关（Adsterra key）
# 留空 = 全站不显示广告；填入 key = 启用所有广告位
# ⚠️ 敏感信息，请在部署平台设置，不要在此填入真实 key
NEXT_PUBLIC_AD_BANNER_KEY=875f69358384025a61405d869db1c3c3
